# ---------------------------------------------------------------------------
# Family Finance — Variables de entorno
# Copia este fichero a `.env` y rellena los valores reales.
# Nunca subas tu `.env` real al repositorio.
# ---------------------------------------------------------------------------

# --- Base de datos (PostgreSQL / Supabase) -------------------------------
# Cadena de conexión con pooling (uso en runtime, p. ej. Supabase pooler 6543)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/family_finance?schema=public"
# Conexión directa (migraciones de Prisma; en Supabase usa el puerto 5432)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/family_finance?schema=public"

# --- Supabase ------------------------------------------------------------
# Disponibles en el panel de Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Solo en servidor. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- OAuth Google (configurado en Supabase Auth > Providers) -------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Family Finance"
# Moneda y locale por defecto
NEXT_PUBLIC_DEFAULT_CURRENCY="EUR"
NEXT_PUBLIC_DEFAULT_LOCALE="es-ES"

# --- Seguridad -----------------------------------------------------------
# Clave de 32 bytes (base64) para cifrado de datos sensibles en reposo.
# Genera una con: openssl rand -base64 32
ENCRYPTION_KEY="generate-a-32-byte-base64-key"
